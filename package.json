{
  "name": "curalink-workspace",
  "private": true,
  "scripts": {
    "start": "npm run start:all",
    "start:all": "node start.js",
    "context:refresh": "node scripts/generate-project-context.mjs",
    "rewrite": "npm --prefix client run rewrite --",
    "rewrite:no-open": "npm --prefix client run rewrite:no-open --",
    "check:server": "npm --prefix server run check",
    "check:client": "npm --prefix client run check",
    "check:llm": "python -m py_compile llm-service/main.py",
    "check:integration": "node scripts/integration-smoke.mjs",
    "doctor": "npm run context:refresh && npm run check:server && npm run check:client && npm run check:llm && npm run check:integration"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.7"
  }
}
