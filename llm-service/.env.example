# Generation: Groq only. GROQ_API_KEY is required.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
PRIMARY_LLM_PROVIDER=groq
LOCAL_FALLBACK_ENABLED=true

# PDF RAG configuration
CHROMA_PERSIST_DIR=./chroma_store
PDF_MAX_SIZE_MB=20
PDF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
PDF_TOP_K_RETRIEVAL=6

# Optional Ollama embedding fallback for /embed only
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_SEC=20
