# Required: MongoDB Atlas SRV URI only.
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/curalink?retryWrites=true&w=majority

# Service endpoints
LLM_SERVICE_URL=http://127.0.0.1:8001
FRONTEND_URL=http://localhost:5173
PORT=5000

# Generation: Groq only. GROQ_API_KEY is required.

# Runtime
NODE_ENV=development
APP_VERSION=1.0.0
TRUST_PROXY=0
PUBMED_EMAIL=you@example.com

# MongoDB connection tuning
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=30000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0
MONGODB_MAX_IDLE_MS=30000

# Server caches and LLM HTTP keep-alive
QUERY_CACHE_TTL_MS=300000
QUERY_CACHE_MAX_ENTRIES=500
LLM_KEEP_ALIVE_MS=30000
LLM_MAX_SOCKETS=50

# Scheduler
ANALYTICS_SCHEDULER_ENABLED=true
ANALYTICS_SNAPSHOT_CRON=0 * * * *
