# URL-encode special characters in the password (example: @ => %40).
# If Atlas SRV DNS lookups fail on Windows, switch to a non-SRV URI with explicit hosts.
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/curalink?retryWrites=true&w=majority
# Optional non-SRV fallback URI (recommended for Windows DNS/SRV issues).
MONGODB_URI_FALLBACK=mongodb://username:password@cluster0-shard-00-00.example.mongodb.net:27017,cluster0-shard-00-01.example.mongodb.net:27017,cluster0-shard-00-02.example.mongodb.net:27017/curalink?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
# Optional local Mongo fallback URI.
MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/curalink?directConnection=true
# Allow using local Mongo URI fallback in production only when explicitly enabled.
MONGODB_ALLOW_LOCAL_FALLBACK=false
# Enable in-memory Mongo fallback when no external MongoDB is reachable.
MONGODB_MEMORY_FALLBACK=false
LLM_SERVICE_URL=http://127.0.0.1:8001
# Comma-separated allowed origins for browser access.
FRONTEND_URL=http://localhost:5173
PORT=5000
# Set explicitly per deployment topology (for example 1 behind reverse proxy).
TRUST_PROXY=0
NODE_ENV=development
PUBMED_EMAIL=you@example.com
